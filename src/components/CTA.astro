---
import { SOCIAL } from '../config';
---

<section class="py-16 px-6 reveal">
  <div class="max-w-3xl mx-auto text-center">
    <div class="p-10 rounded-2xl border border-copper-500/10 bg-gradient-to-br from-copper-500/5 to-transparent">
      <h2 class="text-2xl md:text-3xl font-bold mb-4" style="font-family: var(--font-heading)">
        Let's work together
      </h2>
      <p class="text-muted-500 mb-8 max-w-lg mx-auto">
        Whether you're dealing with fragmented data, a BI platform in need of modernization, or an AI automation idea you want to turn into a production system, I'm available for project and advisory work.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <a
          href="mailto:saamir259@gmail.com?subject=Let's%20work%20together"
          class="inline-flex items-center gap-2 px-6 py-2.5 bg-copper-500 hover:bg-copper-400 text-carbon-950 font-semibold text-sm rounded-lg transition-colors"
        >
          Let's Talk
        </a>
        <a
          href={SOCIAL.linkedin}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 px-6 py-2.5 border border-copper-500/40 hover:border-copper-400 text-copper-400 hover:text-copper-300 font-semibold text-sm rounded-lg transition-colors"
        >
          Connect on LinkedIn
        </a>
      </div>
    </div>
  </div>
</section>
