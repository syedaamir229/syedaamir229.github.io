---
type IconName =
  | 'email'
  | 'linkedin'
  | 'github'
  | 'tableau'
  | 'arrow-right'
  | 'arrow-left'
  | 'menu'
  | 'close'
  | 'database'
  | 'chart'
  | 'brain'
  | 'robot';

interface Props {
  name: IconName;
  class?: string;
  size?: number;
}

const { name, class: className = 'w-4 h-4', size } = Astro.props;
const sizeStyle = size ? `width:${size}px;height:${size}px;` : undefined;

// fill: solid path (single <path>)
// stroke: line drawing (stroke + path)
type IconDef = { mode: 'fill' | 'stroke'; path: string; strokeWidth?: number };

const ICONS: Record<IconName, IconDef> = {
