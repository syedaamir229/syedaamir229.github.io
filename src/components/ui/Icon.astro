const def = ICONS[name];
---

{def.mode === 'fill' ? (
  <svg class={className} style={sizeStyle} fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
    <path d={def.path} />
  </svg>
) : (
  <svg
    class={className}
    style={sizeStyle}
    fill="none"
    stroke="currentColor"
    viewBox="0 0 24 24"
    stroke-width={def.strokeWidth ?? 2}
    aria-hidden="true"
  >
    <path stroke-linecap="round" stroke-linejoin="round" d={def.path} />
  </svg>
)}
