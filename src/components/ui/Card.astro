---
interface Props {
  as?: 'div' | 'a' | 'article' | 'li';
  href?: string;
  hover?: boolean;
  padding?: 'none' | 'sm' | 'md' | 'lg';
  class?: string;
  'data-category'?: string;
  'data-categories'?: string;
}

const {
  as: Element = 'div',
  href,
  hover = false,
  padding = 'md',
  class: className = '',
  ...rest
} = Astro.props;

const paddingClass =
  padding === 'none' ? '' : padding === 'sm' ? 'p-4' : padding === 'lg' ? 'p-6 md:p-7' : 'p-6';
const hoverClass = hover ? 'card-hover group' : '';
---

<Element
  href={href}
  class:list={[
    'block rounded-xl border border-cream-100/5 bg-navy-800/40',
    paddingClass,
    hoverClass,
    className,
  ]}
  {...rest}
>
  <slot />
</Element>
