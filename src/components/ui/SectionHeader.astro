---
import Eyebrow from './Eyebrow.astro';

interface Props {
  eyebrow: string;
  title: string;
  description?: string;
  class?: string;
}

const { eyebrow, title, description, class: className = 'mb-10 max-w-2xl' } = Astro.props;
---

<div class={className}>
  <Eyebrow class="mb-3">{eyebrow}</Eyebrow>
  <h2 class="text-2xl md:text-3xl font-bold mb-2">
    {title}
  </h2>
  {description && (
    <p class="text-muted-500 text-sm">
      {description}
    </p>
  )}
</div>
