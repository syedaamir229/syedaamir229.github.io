---
type Variant = 'primary' | 'outline' | 'pill';

interface Props {
  href?: string;
  variant?: Variant;
  target?: string;
  rel?: string;
  class?: string;
}

const { href, variant = 'primary', target, rel, class: className = '' } = Astro.props;

const base = 'inline-flex items-center gap-2 font-medium text-sm transition-colors';

const variantClass: Record<Variant, string> = {
  primary:
    'gap-2 px-6 py-3 bg-cyan-500 hover:bg-cyan-400 text-navy-950 font-bold rounded-lg',
  outline:
    'gap-2 px-6 py-3 rounded-lg border border-cream-100/10 hover:border-cyan-400 text-cream-100 hover:text-cyan-400 font-semibold',
  pill:
    'gap-2.5 px-5 py-3 rounded-full border border-cyan-500/40 hover:border-cyan-400 bg-cyan-500/5 hover:bg-cyan-500/10 text-cream-100 hover:text-cyan-300',
};

const Tag = href ? 'a' : 'button';
---

<Tag href={href} target={target} rel={rel} class:list={[base, variantClass[variant], className]}>
  <slot />
</Tag>
