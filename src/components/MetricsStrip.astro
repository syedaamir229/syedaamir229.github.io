---
import { METRICS } from '../config';
---

<section class="py-12 px-6 reveal">
  <div class="max-w-4xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-8">
    {METRICS.map((metric) => (
      <div class="text-center">
        <p class="text-3xl md:text-4xl font-bold gradient-text" style="font-family: var(--font-heading)">
          {metric.value}
        </p>
        <p class="text-muted-500 text-sm mt-1">{metric.label}</p>
      </div>
    ))}
  </div>
</section>
