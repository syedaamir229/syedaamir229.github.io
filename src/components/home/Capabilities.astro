---
import { CAPABILITIES } from '../../data/capabilities';
import Eyebrow from '../ui/Eyebrow.astro';
import CapabilityCard from './CapabilityCard.astro';
---

<section class="py-20 px-6 reveal">
  <div class="max-w-6xl mx-auto grid lg:grid-cols-[1fr_2fr] gap-10 lg:gap-16">
    <div class="lg:sticky lg:top-24 lg:self-start">
      <Eyebrow class="mb-3">What I Build</Eyebrow>
      <h2 class="text-3xl md:text-4xl font-bold leading-tight mb-4">
        Four practices, one connected system.
      </h2>
      <p class="text-muted-500 text-base leading-relaxed">
        Each one stands alone as an engagement. Together they cover the full path from raw data to AI in production.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-1 gap-6">
      {CAPABILITIES.map((cap) => <CapabilityCard capability={cap} />)}
    </div>
  </div>
</section>
