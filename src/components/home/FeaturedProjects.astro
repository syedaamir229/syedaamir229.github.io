---
import { getPublishedProjects } from '../../lib/projects';
import { PROJECTS_TAGLINE } from '../../data/projects';
import Card from '../ui/Card.astro';
import Eyebrow from '../ui/Eyebrow.astro';
import Tag from '../ui/Tag.astro';

const projects = (await getPublishedProjects({ featuredOnly: true, limit: 4 })).map((p) => {
  const heroMetric = p.data.metrics?.[0];
  return {
    title: p.data.title,
    description: p.data.description,
    tags: (p.data.tags ?? []).slice(0, 3),
    metric: heroMetric ? `${heroMetric.value} ${heroMetric.label}`.trim() : null,
    href: `/projects/${p.id}/`,
  };
});
---

<section class="py-16 px-6 reveal">
  <div class="max-w-6xl mx-auto">
    <div class="flex items-start justify-between gap-6 mb-10">
      <div>
        <Eyebrow class="mb-3">Recent Work</Eyebrow>
        <h2 class="text-2xl md:text-3xl font-bold mb-2">
          Where this has paid off.
        </h2>
        <p class="text-muted-500 text-sm max-w-xl">
          {PROJECTS_TAGLINE}
        </p>
      </div>
      <a href="/projects/" class="shrink-0 text-cyan-400 hover:text-cyan-300 text-sm font-medium transition-colors mt-1">
        View all <span aria-hidden="true">&rarr;</span>
      </a>
    </div>
    <div class="grid md:grid-cols-2 gap-6">
      {projects.map((project) => (
        <Card as="a" href={project.href} hover>
          {project.metric && (
            <div class="flex items-center gap-2 mb-3">
              <Tag>{project.metric}</Tag>
            </div>
          )}
          <h3 class="text-cream-100 font-semibold text-lg mb-2 group-hover:text-cyan-400 transition-colors">
            {project.title}
          </h3>
          <p class="text-muted-500 text-sm leading-relaxed mb-4">
            {project.description}
          </p>
          <div class="flex flex-wrap gap-2">
            {project.tags.map((tag) => (
              <Tag variant="tag">{tag}</Tag>
            ))}
          </div>
        </Card>
      ))}
    </div>
  </div>
</section>
