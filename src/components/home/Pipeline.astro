---
import { PIPELINE_STAGES, PIPELINE_PHASE_META } from '../../data/pipeline';
import Eyebrow from '../ui/Eyebrow.astro';
import PipelineStage from './PipelineStage.astro';
---

<section class="py-20 px-6 reveal">
  <div class="max-w-6xl mx-auto grid lg:grid-cols-[1fr_2fr] gap-10 lg:gap-16">
    <div class="lg:sticky lg:top-24 lg:self-start">
      <Eyebrow class="mb-3">How I Work</Eyebrow>
      <h2 class="text-3xl md:text-4xl font-bold leading-tight mb-4">
        Turning scattered data into decisions your business can trust.
      </h2>
      <p class="text-muted-500 text-base leading-relaxed">
        Every dashboard, forecast, and AI agent rests on the same foundation. Here is how each layer builds on the last.
      </p>
    </div>

    <div class="relative">
      {PIPELINE_STAGES.map((stage, i) => {
        const isPhaseStart = i === 0 || PIPELINE_STAGES[i - 1].phase !== stage.phase;
        const meta = PIPELINE_PHASE_META[stage.phase];
        const nextSameGroup =
          i < PIPELINE_STAGES.length - 1 && PIPELINE_STAGES[i + 1].phase === stage.phase;
        return (
          <>
            {isPhaseStart && (
              <div class:list={['flex items-center gap-4', i === 0 ? 'mb-6' : 'my-10']}>
                <div class="h-px flex-1 bg-cyan-500/20"></div>
                <div class="text-center shrink-0">
                  <Eyebrow>{meta.label}</Eyebrow>
                  <p class="text-xs text-muted-500 mt-1 italic">{meta.caption}</p>
                </div>
                <div class="h-px flex-1 bg-cyan-500/20"></div>
              </div>
            )}
            <PipelineStage stage={stage} index={i} showConnector={nextSameGroup} />
          </>
        );
      })}
    </div>
  </div>
</section>
