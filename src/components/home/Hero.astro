---
import { SITE, SOCIAL } from '../../config';
import { CURRENT_ROLE } from '../../data/experience';
import Button from '../ui/Button.astro';
import Icon from '../ui/Icon.astro';
---

<section class="pt-32 pb-16 px-6">
  <div class="max-w-6xl mx-auto grid md:grid-cols-[1.4fr_1fr] gap-8 md:gap-10 lg:gap-12 items-center">
    <!-- Text -->
    <div class="animate-fade-in-up">
      <div class="flex items-center gap-3 mb-4 md:mb-4">
        <img
          src={SITE.avatar}
          alt={SITE.name}
          class="md:hidden w-10 h-10 rounded-full object-cover object-top border border-cyan-500/40"
          loading="eager"
        />
        <p class="text-cyan-400 text-sm font-mono font-medium tracking-wide uppercase">
          {SITE.title}
        </p>
      </div>
      <h1 class="text-4xl md:text-5xl lg:text-[3.25rem] font-bold leading-[1.15] mb-6">
        Data that works as hard<br />
        as your <span class="gradient-text">business does.</span>
      </h1>
      <ul class="space-y-3 text-cream-200 text-[0.95rem] mb-8">
        <li class="flex items-start gap-3">
          <span class="text-cyan-400 mt-0.5 shrink-0" aria-hidden="true">&rarr;</span>
          <span>AI that moves the business forward, not just demos well in a meeting</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-cyan-400 mt-0.5 shrink-0" aria-hidden="true">&rarr;</span>
          <span>Manual work automated so teams focus on what actually matters</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-cyan-400 mt-0.5 shrink-0" aria-hidden="true">&rarr;</span>
          <span>Decisions backed by numbers that everyone trusts</span>
        </li>
      </ul>
      <p class="text-muted-500 text-sm mb-2">
        10+ years &middot; Analytics, Data Engineering, Data Science & AI Automation &middot; Dubai, UAE
      </p>
      {CURRENT_ROLE && (
        <p class="text-muted-500 text-sm mb-8">
          <span class="text-cream-200">Currently:</span> {CURRENT_ROLE.title}, {CURRENT_ROLE.company}
        </p>
      )}
      <div class="flex flex-wrap items-center gap-4">
        <Button variant="primary" href={SOCIAL.emailCompose} target="_blank" rel="noopener">
          <Icon name="email" />
          Let's Talk
        </Button>
        <a
          href="/projects/"
          class="text-sm font-medium text-muted-500 hover:text-cyan-400 transition-colors"
        >
          View projects <span aria-hidden="true">&rarr;</span>
        </a>
      </div>
    </div>

    <!-- Profile image -->
    <div class="hidden md:flex justify-center md:justify-end animate-fade-in-up" style="animation-delay: 0.2s">
      <div class="relative">
        <div class="absolute -inset-1 bg-gradient-to-br from-cyan-500/20 to-transparent rounded-2xl blur-xl"></div>
        <img
          src={SITE.avatar}
          alt={`${SITE.name} - ${SITE.title} based in Dubai`}
          class="relative w-32 h-32 md:w-56 md:h-56 lg:w-72 lg:h-72 object-cover object-top rounded-2xl border-2 border-cyan-500/30 shadow-2xl"
          loading="eager"
        />
      </div>
    </div>
  </div>
</section>
