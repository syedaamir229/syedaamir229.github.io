---
import { SITE } from '../config';
---

<section class="pt-32 pb-16 px-6">
  <div class="max-w-6xl mx-auto grid lg:grid-cols-[1.4fr_1fr] gap-12 items-center">
    <!-- Text -->
    <div class="animate-fade-in-up">
      <p class="text-copper-400 text-sm font-mono font-medium tracking-wide uppercase mb-4">
        {SITE.title}
      </p>
      <h1 class="text-4xl md:text-5xl lg:text-[3.25rem] font-bold leading-[1.15] mb-6" style="font-family: var(--font-heading)">
        Data that works as hard<br />
        as your <span class="gradient-text">business does.</span>
      </h1>
      <ul class="space-y-3 text-cream-200 text-[0.95rem] mb-8">
        <li class="flex items-start gap-3">
          <span class="text-copper-400 mt-0.5 shrink-0">&rarr;</span>
          <span>AI that moves the business forward, not just demos well in a meeting</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-copper-400 mt-0.5 shrink-0">&rarr;</span>
          <span>Manual work automated so teams focus on what actually matters</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-copper-400 mt-0.5 shrink-0">&rarr;</span>
          <span>Decisions backed by numbers that everyone trusts</span>
        </li>
      </ul>
      <p class="text-muted-500 text-sm mb-2">
        10+ years &middot; Analytics, Data Engineering, Data Science & AI Automation &middot; Dubai, UAE
      </p>
      <p class="text-muted-500 text-sm mb-8">
        <span class="text-cream-200">Currently:</span> Assistant Analytics Manager, Shahid (MBC Group)
      </p>
      <div class="flex flex-wrap items-center gap-4">
        <a
          href="mailto:saamir259@gmail.com?subject=Let's%20talk"
          class="inline-flex items-center gap-2 px-6 py-3 bg-copper-500 hover:bg-copper-400 text-carbon-950 font-semibold text-sm rounded-lg transition-colors"
        >
          Let's Talk
        </a>
        <a
          href="/projects/"
          class="text-sm font-medium text-muted-500 hover:text-copper-400 transition-colors"
        >
          View case studies &rarr;
        </a>
      </div>
    </div>

    <!-- Profile image -->
    <div class="flex justify-center lg:justify-end animate-fade-in-up" style="animation-delay: 0.2s">
      <div class="relative">
        <div class="absolute -inset-1 bg-gradient-to-br from-copper-500/20 to-transparent rounded-2xl blur-xl"></div>
        <img
          src="/assets/syedaamir.jpeg"
          alt="Syed Aamir - Data and AI Solutions Engineer based in Dubai"
          class="relative w-56 h-56 object-cover object-top rounded-2xl border-2 border-copper-500/30 shadow-2xl"
          loading="eager"
        />
      </div>
    </div>
  </div>
</section>
