---
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects'))
  .filter((p) => p.data.featured)
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
  .slice(0, 4)
  .map((p) => {
    const heroMetric = p.data.metrics?.[0];
    return {
      title: p.data.title,
      description: p.data.description,
      tags: (p.data.tags ?? []).slice(0, 3),
      metric: heroMetric ? `${heroMetric.value} ${heroMetric.label}`.trim() : null,
      href: `/projects/${p.id}/`,
    };
  });
---

<section class="py-16 px-6 reveal">
  <div class="max-w-6xl mx-auto">
    <div class="flex items-start justify-between gap-6 mb-10">
      <div>
        <h2 class="text-2xl md:text-3xl font-bold mb-2" style="font-family: var(--font-heading)">
          Featured Work
        </h2>
        <p class="text-muted-500 text-sm max-w-xl">
          Selected projects from 10 years of delivery across data platforms, analytics, and AI automation.
        </p>
      </div>
      <a href="/projects/" class="shrink-0 text-copper-400 hover:text-copper-300 text-sm font-medium transition-colors mt-1">
        View all &rarr;
      </a>
    </div>
    <div class="grid md:grid-cols-2 gap-6">
      {projects.map((project) => (
        <a href={project.href} class="group block p-6 rounded-xl border border-cream-100/5 bg-carbon-800/40 card-hover">
          {project.metric && (
            <div class="flex items-center gap-2 mb-3">
              <span class="text-xs font-mono text-copper-400 bg-copper-500/10 px-2 py-0.5 rounded">
                {project.metric}
              </span>
            </div>
          )}
          <h3 class="text-cream-100 font-semibold text-lg mb-2 group-hover:text-copper-400 transition-colors" style="font-family: var(--font-heading)">
            {project.title}
          </h3>
          <p class="text-muted-500 text-sm leading-relaxed mb-4">
            {project.description}
          </p>
          <div class="flex flex-wrap gap-2">
            {project.tags.map((tag) => (
              <span class="text-xs text-muted-500 border border-cream-100/5 px-2 py-0.5 rounded">
                {tag}
              </span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
