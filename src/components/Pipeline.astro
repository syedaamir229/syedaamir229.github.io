---
const stages = [
  { label: 'Data Sources', color: 'from-orange-400 to-orange-500' },
  { label: 'Ingestion & Storage', color: 'from-rose-400 to-rose-500' },
  { label: 'Data Modeling', color: 'from-purple-400 to-purple-500' },
  { label: 'Semantic Layer', color: 'from-blue-400 to-blue-500' },
  { label: 'Analytics & BI', color: 'from-copper-400 to-copper-500' },
  { label: 'Data Science', color: 'from-emerald-400 to-emerald-500' },
  { label: 'AI & Automation', color: 'from-cyan-400 to-cyan-500' },
];
---

<section class="py-16 px-6 reveal">
  <div class="max-w-6xl mx-auto">
    <div class="flex flex-wrap justify-center gap-3 xl:gap-0 xl:flex-nowrap items-center">
      {stages.map((stage, i) => (
        <div
          class="pipeline-stage flex items-center opacity-0"
          style={`animation: fade-in-up 0.5s ease forwards; animation-delay: ${i * 0.15}s;`}
        >
          <div class={`bg-gradient-to-r ${stage.color} text-cream-100 text-xs font-semibold px-4 py-2 rounded-lg whitespace-nowrap shadow-lg`}>
            {stage.label}
          </div>
          {i < stages.length - 1 && (
            <div class="hidden xl:block w-6 h-px bg-gradient-to-r from-white/20 to-white/5 mx-1"></div>
          )}
        </div>
      ))}
    </div>
    <p class="text-center text-muted-500 text-xs font-mono mt-4 tracking-wider uppercase">
      Source to Outcome
    </p>
  </div>
</section>
