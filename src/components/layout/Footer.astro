---
import { SITE, SOCIAL } from '../../config';
import Icon from '../ui/Icon.astro';

const socialLinks = [
  { href: SOCIAL.linkedin, name: 'linkedin' as const, label: 'LinkedIn' },
  { href: SOCIAL.github, name: 'github' as const, label: 'GitHub' },
  { href: SOCIAL.tableau, name: 'tableau' as const, label: 'Tableau Public' },
  { href: SOCIAL.emailCompose, name: 'email' as const, label: 'Email' },
];
---

<footer class="border-t border-cream-100/5 bg-navy-950 mt-24">
  <div class="max-w-6xl mx-auto px-6 py-12">
    <div class="flex flex-col md:flex-row justify-between items-start gap-6">
      <div class="text-center md:text-left">
        <p class="font-heading text-cream-100 font-semibold">
          <a href={SOCIAL.linkedin} target="_blank" rel="noopener" class="hover:text-cyan-400 transition-colors">
            {SITE.name}
          </a>
        </p>
        <p class="text-sm text-muted-500 mt-1">
          {SITE.title} &middot; {SITE.location}
        </p>
        <p class="text-sm text-muted-500 mt-1">
          Open to project and advisory work.
        </p>
      </div>

      <div class="flex items-center gap-5 md:mt-2">
        {socialLinks.map(({ href, name, label }) => (
          <a
            href={href}
            target="_blank"
            rel="noopener"
            aria-label={label}
            class="text-muted-500 hover:text-cyan-400 transition-colors"
          >
            <Icon name={name} class="w-5 h-5" />
          </a>
        ))}
      </div>
    </div>
  </div>
</footer>
