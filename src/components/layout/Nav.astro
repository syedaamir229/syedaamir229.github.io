---
import { NAV_LINKS, SITE } from '../../config';
import Icon from '../ui/Icon.astro';

const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  currentPath === href || (href !== '/' && currentPath.startsWith(href));
---

<nav class="glass fixed top-0 left-0 right-0 z-50 border-b border-cream-100/5">
  <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class="font-heading text-lg font-bold text-cream-100 hover:text-cyan-400 transition-colors">
      {SITE.name}
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-8">
      {NAV_LINKS.map((link) => (
        <a
          href={link.href}
          class:list={[
            'text-sm font-medium transition-colors',
            isActive(link.href) ? 'text-cyan-400' : 'text-muted-500 hover:text-cream-100',
          ]}
        >
          {link.label}
        </a>
      ))}
    </div>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden text-muted-500 hover:text-cream-100 transition-colors"
      aria-label="Toggle menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <Icon name="menu" class="w-6 h-6 menu-icon-open" />
      <Icon name="close" class="w-6 h-6 menu-icon-close hidden" />
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-cream-100/5 pb-4">
    {NAV_LINKS.map((link) => (
      <a
        href={link.href}
        class:list={[
          'block px-6 py-3 text-sm font-medium transition-colors',
          isActive(link.href) ? 'text-cyan-400' : 'text-muted-500 hover:text-cream-100',
        ]}
      >
        {link.label}
      </a>
    ))}
  </div>
</nav>

<script>
  import '../../scripts/mobileMenu';
</script>
