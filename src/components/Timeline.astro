---
const experience = [
  {
    company: 'Shahid (MBC Group)',
    role: 'Assistant Advanced Analytics & Insights Manager',
    period: '2022 - Present',
    location: 'Dubai, UAE',
    current: true,
  },
  {
    company: 'Beinex',
    role: 'Senior Consultant - Analytics',
    period: '2019 - 2022',
    location: 'Dubai, UAE',
    current: false,
  },
  {
    company: 'Al-Futtaim Engineering',
    role: 'Business Intelligence Consultant',
    period: '2018 - 2019',
    location: 'Dubai, UAE',
    current: false,
  },
  {
    company: 'Scan Technology',
    role: 'Business Intelligence Consultant',
    period: '2016 - 2018',
    location: 'Dubai, UAE',
    current: false,
  },
];
---

<section class="py-16 px-6 reveal">
  <div class="max-w-6xl mx-auto">
    <div class="flex items-center justify-between mb-12">
      <h2 class="text-2xl md:text-3xl font-bold" style="font-family: var(--font-heading)">
        Experience
      </h2>
      <a href="/experience/" class="text-copper-400 hover:text-copper-300 text-sm font-medium transition-colors">
        Full timeline &rarr;
      </a>
    </div>
    <div class="relative">
      <!-- Timeline line -->
      <div class="absolute left-4 top-0 bottom-0 w-px bg-gradient-to-b from-copper-500/60 via-copper-500/20 to-transparent"></div>

      <div class="space-y-8">
        {experience.map((exp) => (
          <div class="relative pl-12">
            <!-- Dot -->
            <div class:list={[
              'absolute left-2.5 top-1.5 w-3 h-3 rounded-full border-2',
              exp.current
                ? 'border-copper-400 bg-copper-400/20'
                : 'border-muted-600 bg-carbon-900',
            ]}></div>

            <div>
              <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
                <h3 class="text-cream-100 font-semibold" style="font-family: var(--font-heading)">
                  {exp.company}
                </h3>
                <span class="text-xs text-muted-500 font-mono">{exp.period}</span>
              </div>
              <p class="text-muted-500 text-sm">{exp.role}</p>
              <p class="text-muted-500 text-xs mt-0.5">{exp.location}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
