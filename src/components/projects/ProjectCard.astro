---
import type { CollectionEntry } from 'astro:content';
import Tag from '../ui/Tag.astro';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { title, description, category, metrics, tags } = project.data;
---

<a
  href={`/projects/${project.id}/`}
  class="group block p-6 rounded-xl border border-cream-100/5 bg-navy-800/40 card-hover"
  data-categories={JSON.stringify([category])}
>
  <Tag>{category}</Tag>
  <h3 class="text-cream-100 font-semibold text-lg mt-3 mb-2 group-hover:text-cyan-400 transition-colors">
    {title}
  </h3>
  <p class="text-muted-500 text-sm line-clamp-3 mb-4">
    {description}
  </p>
  {metrics.length > 0 && (
    <div class="flex flex-wrap gap-4 mt-auto pt-3 border-t border-cream-100/5">
      {metrics.slice(0, 2).map((m) => (
        <div>
          <p class="text-sm font-bold text-cyan-400">{m.value}</p>
          <p class="text-xs text-muted-500">{m.label}</p>
        </div>
      ))}
    </div>
  )}
  {tags.length > 0 && (
    <div class="flex flex-wrap gap-1.5 mt-3">
      {tags.slice(0, 4).map((tag) => (
        <Tag variant="tag">{tag}</Tag>
      ))}
    </div>
  )}
</a>
