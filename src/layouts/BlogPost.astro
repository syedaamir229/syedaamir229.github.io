---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import PostHeader from '../components/blog/PostHeader.astro';
import SeriesNav from '../components/blog/SeriesNav.astro';
import type { SeriesInfo } from '../lib/series';

interface Props {
  post: CollectionEntry<'blog'>;
  readingTime: number;
  seriesInfo: SeriesInfo | null;
}

const { post, readingTime, seriesInfo } = Astro.props;
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  ogImage={`/og/blog/${post.id}.png`}
>
  <article class="pt-32 pb-16 px-6">
    <div class="max-w-3xl mx-auto">
      <nav class="mb-8 text-xs font-mono text-muted-500" aria-label="Breadcrumb">
        <a href="/blog/" class="hover:text-cyan-400 transition-colors">
          <span aria-hidden="true">&larr;</span> All posts
        </a>
      </nav>

      <PostHeader post={post} readingTime={readingTime} seriesInfo={seriesInfo} />

      <div class="prose">
        <slot />
      </div>

      {seriesInfo && <SeriesNav seriesInfo={seriesInfo} />}

      <div class="mt-16 pt-8 border-t border-cream-100/5">
        <a
          href="/blog/"
          class="text-cyan-400 hover:text-cyan-300 text-sm font-medium transition-colors"
        >
          <span aria-hidden="true">&larr;</span> All posts
        </a>
      </div>
    </div>
  </article>
</BaseLayout>
