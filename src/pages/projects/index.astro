---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/ui/PageHeader.astro';
import Eyebrow from '../../components/ui/Eyebrow.astro';
import ProjectGrid from '../../components/projects/ProjectGrid.astro';
import { getPublishedProjects } from '../../lib/projects';
import { PROJECTS_TAGLINE } from '../../data/projects';

const allProjects = await getPublishedProjects();
const enterpriseProjects = allProjects.filter(
  (p) => (p.data.kind ?? 'enterprise') === 'enterprise',
);
const personalProjects = allProjects.filter((p) => p.data.kind === 'personal');
---

<BaseLayout
  title="Projects"
  description="Projects across data engineering, BI, data science, and AI automation."
>
  <PageHeader
    eyebrow="Projects"
    title="Real builds, real constraints, real outcomes."
    description={PROJECTS_TAGLINE}
  />

  <section class="py-16 px-6 reveal">
    <div class="max-w-6xl mx-auto space-y-20">
      {enterpriseProjects.length > 0 && (
        <div>
          <Eyebrow class="mb-3">Enterprise work</Eyebrow>
          <h2 class="text-2xl md:text-3xl font-bold leading-tight mb-3">
            Delivered in production, at scale
          </h2>
          <p class="text-muted-500 text-base leading-relaxed max-w-2xl mb-8">
            Data and analytics systems built inside a large consumer business,
            anonymized for confidentiality.
          </p>
          <ProjectGrid projects={enterpriseProjects} />
        </div>
      )}

      {personalProjects.length > 0 && (
        <div>
          <Eyebrow class="mb-3">Personal builds</Eyebrow>
          <h2 class="text-2xl md:text-3xl font-bold leading-tight mb-3">
            Built end to end, on my own
          </h2>
          <p class="text-muted-500 text-base leading-relaxed max-w-2xl mb-8">
            Full-stack systems I designed, built, and deployed myself, from
            ingestion to interface.
          </p>
          <ProjectGrid projects={personalProjects} />
        </div>
      )}
    </div>
  </section>
</BaseLayout>
