---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allProjects = (await getCollection('projects'))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

const recentProjects = allProjects.filter((p) => (p.data.order ?? 99) < 20);
const earlierProjects = allProjects.filter((p) => {
  const o = p.data.order ?? 99;
  return o >= 20 && o < 100;
});

const categories = [...new Set(allProjects.map((p) => p.data.category))].sort();
---

<BaseLayout title="Projects" description="Case studies from 10+ years of data engineering, BI, data science, and AI automation work.">
  <section class="pt-32 pb-16 px-6">
    <div class="max-w-6xl mx-auto">
      <h1 class="text-3xl md:text-4xl font-bold mb-4" style="font-family: var(--font-heading)">Projects</h1>
      <p class="text-muted-500 mb-12 max-w-2xl">
        Case studies from real work across data architecture, BI modernization, data science, and AI automation.
      </p>

      <!-- Category filters -->
      <div class="flex flex-wrap gap-2 mb-10">
        <button class="proj-cat-btn active text-xs font-mono px-3 py-1.5 rounded border border-copper-500/40 text-copper-400 bg-copper-500/10 transition-colors" data-category="all">
          All
        </button>
        {categories.map((cat) => (
          <button class="proj-cat-btn text-xs font-mono px-3 py-1.5 rounded border border-cream-100/10 text-muted-500 hover:border-copper-500/40 hover:text-copper-400 transition-colors" data-category={cat}>
            {cat}
          </button>
        ))}
      </div>

      <!-- Recent Work -->
      <div class="proj-section" data-section="recent">
        <h2 class="proj-section-heading text-[11px] font-mono text-copper-400 uppercase tracking-[0.18em] mb-4">
          Recent Work
        </h2>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 mb-16">
          {recentProjects.map((project) => (
            <a
              href={`/projects/${project.id}/`}
              class="proj-card group block p-6 rounded-xl border border-cream-100/5 bg-carbon-800/40 card-hover"
              data-category={project.data.category}
            >
              <span class="text-xs font-mono text-copper-400 bg-copper-500/10 px-2 py-0.5 rounded">
                {project.data.category}
              </span>
              <h3 class="text-cream-100 font-semibold text-lg mt-3 mb-2 group-hover:text-copper-400 transition-colors" style="font-family: var(--font-heading)">
                {project.data.title}
              </h3>
              <p class="text-muted-500 text-sm line-clamp-3 mb-4">
                {project.data.description}
              </p>
              {project.data.metrics.length > 0 && (
                <div class="flex flex-wrap gap-4 mt-auto pt-3 border-t border-cream-100/5">
                  {project.data.metrics.slice(0, 2).map((m) => (
                    <div>
                      <p class="text-sm font-bold text-copper-400">{m.value}</p>
                      <p class="text-xs text-muted-500">{m.label}</p>
                    </div>
                  ))}
                </div>
              )}
              {project.data.tags.length > 0 && (
                <div class="flex flex-wrap gap-1.5 mt-3">
                  {project.data.tags.slice(0, 4).map((tag) => (
                    <span class="text-xs text-muted-500 border border-cream-100/5 px-1.5 py-0.5 rounded">
                      {tag}
                    </span>
                  ))}
                </div>
              )}
            </a>
          ))}
        </div>
      </div>

      <!-- Earlier Consulting -->
      {earlierProjects.length > 0 && (
        <div class="proj-section" data-section="earlier">
          <h2 class="proj-section-heading text-[11px] font-mono text-muted-500 uppercase tracking-[0.18em] mb-2">
            Earlier Consulting
          </h2>
          <p class="text-muted-500 text-sm mb-6 max-w-2xl">
            Pre-Shahid engagements from 2017 to 2022 across enterprise BI, finance, automotive, and government.
          </p>
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4 mb-16">
            {earlierProjects.map((project) => (
              <a
                href={`/projects/${project.id}/`}
                class="proj-card group block p-4 rounded-lg border border-cream-100/5 bg-carbon-800/20 card-hover"
                data-category={project.data.category}
              >
                <span class="text-[10px] font-mono text-muted-500 uppercase tracking-[0.15em]">
                  {project.data.category}
                </span>
                <h3 class="text-cream-100 font-semibold text-base mt-2 mb-1.5 group-hover:text-copper-400 transition-colors" style="font-family: var(--font-heading)">
                  {project.data.title}
                </h3>
                <p class="text-muted-500 text-xs line-clamp-2">
                  {project.data.description}
                </p>
              </a>
            ))}
          </div>
        </div>
      )}

    </div>
  </section>
</BaseLayout>

<script>
  function applyFilter(cat: string) {
    document.querySelectorAll('.proj-card').forEach((card) => {
      const el = card as HTMLElement;
      el.style.display = cat === 'all' || el.dataset.category === cat ? '' : 'none';
    });

    document.querySelectorAll('.proj-section').forEach((section) => {
      const sectionEl = section as HTMLElement;
      const visibleCards = sectionEl.querySelectorAll<HTMLElement>('.proj-card').length === 0
        ? 0
        : Array.from(sectionEl.querySelectorAll<HTMLElement>('.proj-card')).filter(
            (c) => c.style.display !== 'none',
          ).length;
      sectionEl.style.display = visibleCards === 0 ? 'none' : '';
    });
  }

  document.querySelectorAll('.proj-cat-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.proj-cat-btn').forEach((b) => {
        b.classList.remove('active', 'border-copper-500/40', 'text-copper-400', 'bg-copper-500/10');
        b.classList.add('border-cream-100/10', 'text-muted-500');
      });
      btn.classList.add('active', 'border-copper-500/40', 'text-copper-400', 'bg-copper-500/10');
      btn.classList.remove('border-cream-100/10', 'text-muted-500');

      const cat = (btn as HTMLElement).dataset.category ?? 'all';
      applyFilter(cat);
    });
  });
</script>
