---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/ui/PageHeader.astro';
import CategoryFilter from '../../components/ui/CategoryFilter.astro';
import ProjectGrid from '../../components/projects/ProjectGrid.astro';
import { getPublishedProjects } from '../../lib/projects';
import { PRACTICE_AREA_NAMES } from '../../data/categories';

const allProjects = await getPublishedProjects();
const presentCategories = new Set(allProjects.map((p) => p.data.category));
const categories = PRACTICE_AREA_NAMES.filter((c) => presentCategories.has(c));
---

<BaseLayout
  title="Projects"
  description="Projects across data engineering, BI, data science, and AI automation."
>
  <PageHeader
    eyebrow="Projects"
    title="Real builds, real constraints, real outcomes."
    description="Across data platforms, analytics, and AI, in media, retail, government, and automotive."
  />

  <section class="py-16 px-6 reveal">
    <div class="max-w-6xl mx-auto">
      <CategoryFilter categories={categories} />
      <ProjectGrid projects={allProjects} />
    </div>
  </section>
</BaseLayout>
