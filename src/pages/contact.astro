---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SOCIAL, BOOKING } from '../config';
import PageHeader from '../components/ui/PageHeader.astro';
import Button from '../components/ui/Button.astro';
import Icon from '../components/ui/Icon.astro';
---

<BaseLayout title="Contact" description="Get in touch with Syed Aamir about data, BI, and AI projects.">
  <PageHeader
    eyebrow="Contact"
    title="Let's talk."
    description="I'm based in Dubai and work with teams worldwide on data platforms, BI modernization, and AI automation."
    maxWidth="narrow"
  >
    <div class="flex flex-col sm:flex-row gap-3 mt-10">
      <Button variant="primary" href={BOOKING.intro} target="_blank" rel="noopener">
        <Icon name="calendar" />
        Book an intro call
      </Button>
      <Button variant="outline" href={SOCIAL.emailCompose} target="_blank" rel="noopener">
        <Icon name="email" class="w-4 h-4 text-cyan-400" />
        Email me
      </Button>
      <Button variant="outline" href={SOCIAL.linkedin} target="_blank" rel="noopener">
        <Icon name="linkedin" class="w-4 h-4 text-cyan-400" />
        Connect on LinkedIn
      </Button>
    </div>
  </PageHeader>
</BaseLayout>
