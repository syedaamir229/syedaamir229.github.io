---

<BaseLayout title="Experience" description="Career timeline of Syed Aamir across data architecture, BI, data science, and AI automation.">
  <section class="pt-32 pb-16 px-6">
    <div class="max-w-5xl mx-auto">
      <!-- Header -->
      <h1 class="text-3xl md:text-4xl font-bold mb-4" style="font-family: var(--font-heading)">Career Timeline</h1>
      <div class="text-slate-400 text-sm space-y-1 mb-12">
        <p><strong class="text-white">Current:</strong> AI automation & advanced analytics at Shahid (MBC Group)</p>
        <p><strong class="text-white">Scope:</strong> 10+ years across analytics, BI architecture, data science, and AI automation</p>
        <p><strong class="text-white">Industries:</strong> Media & entertainment, retail, automotive, government, enterprise consulting</p>
      </div>

      <!-- Skills -->
      <div class="mb-16 reveal">
        <h2 class="text-2xl font-bold mb-8" style="font-family: var(--font-heading)">Skills & Technologies</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {skills.map((group) => (
            <div class="p-5 rounded-xl border border-white/5 bg-navy-800/40">
              <h3 class="text-sm font-semibold text-white mb-3" style="font-family: var(--font-heading)">{group.category}</h3>
              <div class="flex flex-wrap gap-2">
                {group.items.map((item) => (
                  <span class="text-xs px-2.5 py-1 rounded-md bg-navy-700/60 text-slate-300 border border-white/5">
                    {item}
                  </span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Experience Timeline -->
      <div class="mb-16 reveal">
        <h2 class="text-2xl font-bold mb-8" style="font-family: var(--font-heading)">Professional Experience</h2>
        <div class="relative">
          <div class="absolute left-4 top-0 bottom-0 w-px bg-gradient-to-b from-teal-500/60 via-teal-500/20 to-transparent"></div>

          <div class="space-y-12">
            {experience.map((company) => (
              <div class="relative pl-12">
                <div class:list={[
                  'absolute left-2.5 top-1.5 w-3 h-3 rounded-full border-2',
                  company.current ? 'border-teal-400 bg-teal-400/20' : 'border-slate-600 bg-navy-900',
                ]} />

                <div class="mb-2">
                  <h3 class="text-white font-bold text-lg" style="font-family: var(--font-heading)">{company.company}</h3>
                  <p class="text-xs text-slate-500">{company.tenure} &middot; {company.location}</p>
                </div>

                <div class="space-y-6">
                  {company.roles.map((role) => (
                    <div class="p-4 rounded-lg border border-white/5 bg-navy-800/30">
                      <h4 class="text-white font-semibold text-sm" style="font-family: var(--font-heading)">{role.title}</h4>
                      <p class="text-xs text-slate-500 mb-3">{role.period}</p>
                      <ul class="space-y-1.5">
                        {role.bullets.map((b) => (
                          <li class="text-sm text-slate-400 flex items-start gap-2">
                            <span class="text-teal-500 mt-1 shrink-0 text-xs">&bull;</span>
                            <span>{b}</span>
                          </li>
                        ))}
                      </ul>
                      {role.projects.length > 0 && (
                        <div class="flex flex-wrap gap-2 mt-3 pt-3 border-t border-white/5">
                          {role.projects.map((p) => (
                            <a href={p.href} class="text-xs text-teal-400 hover:text-teal-300 transition-colors">
                              {p.name}
                            </a>
                          ))}
                        </div>
                      )}
                    </div>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Certifications -->
      <div class="mb-16 reveal">
        <h2 class="text-2xl font-bold mb-8" style="font-family: var(--font-heading)">Certifications</h2>

        <h3 class="text-sm font-semibold text-slate-300 uppercase tracking-wider mb-4">Active</h3>
        <div class="flex flex-wrap gap-6 mb-8">
          {activeCerts.map((cert) => (
            <a href={cert.url} target="_blank" rel="noopener" class="transition-transform hover:scale-110" title={cert.name}>
              <img src={cert.badge} alt={cert.name} width="80" height="80" class="rounded-lg opacity-80 hover:opacity-100 transition-opacity" loading="lazy" />
            </a>
          ))}
        </div>

        <h3 class="text-sm font-semibold text-slate-300 uppercase tracking-wider mb-4">Past</h3>
        <div class="flex flex-wrap gap-2">
          {pastCerts.map((cert) => (
            <span class="text-xs px-2.5 py-1 rounded-md bg-navy-800/60 text-slate-500 border border-white/5">
              {cert}
            </span>
          ))}
        </div>
      </div>

      <!-- Education -->
      <div class="mb-16 reveal">
        <h2 class="text-2xl font-bold mb-6" style="font-family: var(--font-heading)">Education</h2>
        <div class="p-5 rounded-xl border border-white/5 bg-navy-800/40 inline-block">
          <h3 class="text-white font-semibold" style="font-family: var(--font-heading)">BITS Pilani, Dubai Campus</h3>
          <p class="text-slate-400 text-sm">B.E. (Hons) in Engineering &middot; 2012 - 2016</p>
        </div>
      </div>

      <!-- CTA -->
      <div class="reveal">
        <div class="p-8 rounded-2xl border border-teal-500/10 bg-gradient-to-br from-teal-500/5 to-transparent text-center">
          <h2 class="text-xl font-bold mb-3" style="font-family: var(--font-heading)">Want to work together?</h2>
          <p class="text-slate-400 text-sm mb-6 max-w-lg mx-auto">
            I'm available for project work, advisory engagements, and staff augmentation across data architecture, analytics, and AI automation.
          </p>
          <div class="flex flex-wrap justify-center gap-3">
            <a href="mailto:saamir259@gmail.com?subject=Let's%20work%20together" class="inline-flex items-center gap-2 px-6 py-2.5 bg-teal-500 hover:bg-teal-400 text-navy-950 font-semibold text-sm rounded-lg transition-colors">
              Let's Talk
            </a>
            <a href="https://www.linkedin.com/in/syedaamiruddin/" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-6 py-2.5 border border-teal-500/40 hover:border-teal-400 text-teal-400 hover:text-teal-300 font-semibold text-sm rounded-lg transition-colors">
              LinkedIn
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
